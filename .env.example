# ─────────────────────────────────────────────────────────────
# Image Generation (optional — image gen 사용 시에만)
# ─────────────────────────────────────────────────────────────

# IMAGE_BACKEND 으로 백엔드 전환 (openai | gemini)
IMAGE_BACKEND=openai

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-image-2

# ── Gemini ────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-image-preview
